# Acceptance environment — copy this file to .env, fill in your keys, then run:
#   docker compose up --build -d
#
# Or run without copying:
#   docker compose --env-file .env.acceptance up --build -d

# ── AI provider ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...

# Connect the session app to the real server (Docker build always sets this)
VITE_MOCK=false

# ── Session app port (browser access) ─────────────────────────────────────────
SESSION_PORT=3000

# ── Optional overrides (defaults are fine for acceptance) ─────────────────────
# AI_PROVIDER=openai
# PORT=3002
