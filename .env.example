# Copy this file to .env and fill in what you need.
# See .env.acceptance for OpenAI setup, .env.local-ai for local model setup.

# ── AI provider ───────────────────────────────────────────────────────────────
# Which provider the demo session uses.  Options: openai | local | gemini
# AI_PROVIDER=openai

# OpenAI (provider: openai)
# OPENAI_API_KEY=sk-...

# Local / self-hosted (provider: local)
# Works with Ollama, llama.cpp, LM Studio, or any OpenAI-compatible endpoint.
# LOCAL_BASE_URL=http://localhost:11434/v1   # Ollama default
# LOCAL_API_KEY=ollama                        # dummy key Ollama needs
# LOCAL_CHAT_MODEL=llama3.2-vision            # vision-capable model

# Image generation for the local provider — pick one:
# A) endpoint also supports OAI /images/generations (Together.ai, etc.)
# LOCAL_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
# B) Automatic1111-compatible Stable Diffusion REST API
# LOCAL_SD_URL=http://localhost:7860
# If neither is set, SVG placeholder sprites are used (good for dev).

# Google Gemini (provider: gemini) — not yet implemented
# GEMINI_API_KEY=...

# ── Server settings (defaults shown) ─────────────────────────────────────────
# PORT=3002
# DB_PATH=./data/kidsproject.db
# UPLOAD_DIR=./uploads

# ── Docker / acceptance ───────────────────────────────────────────────────────
# SESSION_PORT=3000   # host port for the session app container
