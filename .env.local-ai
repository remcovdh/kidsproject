# Local AI environment — no OpenAI key needed.
# Ollama runs in Docker alongside the app via the local-ai profile.
#
# ── Setup ─────────────────────────────────────────────────────────────────────
#   cp .env.local-ai .env
#   docker compose --profile local-ai up --build -d
#   docker compose exec ollama ollama pull gemma3:12b
#   Open http://localhost:3000
#
# GPU acceleration (recommended for acceptable speed):
#   Install nvidia-container-toolkit on your laptop first:
#   https://docs.nvidia.com/datacenter/cloud-native/container-toolkit/install-guide.html
#   Without it Ollama falls back to CPU — still works but noticeably slower.
#
# ── Adding real image generation (optional) ───────────────────────────────────
#   Without LOCAL_SD_URL or LOCAL_IMAGE_MODEL, the local provider generates
#   SVG placeholder sprites — visually distinct per character but not photos.
#
#   Automatic1111 stable-diffusion-webui (run with --api flag):
#     LOCAL_SD_URL=http://host.docker.internal:7860
#
#   Any OAI-compatible image generation endpoint (e.g. Together.ai):
#     LOCAL_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
# ─────────────────────────────────────────────────────────────────────────────

# Switch the demo session to use the local provider on startup
AI_PROVIDER=local

# Ollama runs as a Docker service — the server container reaches it by service name
LOCAL_BASE_URL=http://ollama:11434/v1
LOCAL_API_KEY=ollama
LOCAL_CHAT_MODEL=gemma3:12b

# Image generation — pick one (or leave both empty for SVG sprites)
# LOCAL_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
# LOCAL_SD_URL=http://host.docker.internal:7860

# ── App settings ──────────────────────────────────────────────────────────────
SESSION_PORT=3000

# Connect the session app to the real server (Docker build sets this automatically)
VITE_MOCK=false
