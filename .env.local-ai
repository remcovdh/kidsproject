# Local AI environment — no OpenAI key needed.
#
# Choose your setup:
#
# ── Option A: Ollama running natively on your laptop ─────────────────────────
#   Install:  https://ollama.com/download
#   Start:    ollama serve
#   Pull:     ollama pull llama3.2-vision
#   Run app:  copy this file to .env, then:  npm run dev
#             (flip MOCK_MODE=false in apps/session/api.ts)
#
# ── Option B: Ollama in Docker (acceptance, no native install) ────────────────
#   cp .env.local-ai .env
#   docker compose --profile local-ai up --build -d
#   docker compose exec ollama ollama pull llama3.2-vision
#   Open http://localhost:3000
#
# ── Adding real image generation (optional) ───────────────────────────────────
#   Automatic1111 (AUTOMATIC1111 stable-diffusion-webui) exposes a REST API.
#   Run it with --api flag, then set LOCAL_SD_URL below.
#   Alternatives: any server that exposes POST /sdapi/v1/txt2img compatible API.
#
#   Without LOCAL_SD_URL or LOCAL_IMAGE_MODEL, the local provider uses
#   SVG placeholder sprites — visually distinct per character but not photos.
# ─────────────────────────────────────────────────────────────────────────────

# Switch the demo session to use the local provider on startup
AI_PROVIDER=local

# Chat / vision endpoint
# Use http://ollama:11434/v1 when Ollama runs inside Docker (Option B)
# Use http://localhost:11434/v1 when Ollama runs natively (Option A, npm dev)
LOCAL_BASE_URL=http://ollama:11434/v1
LOCAL_API_KEY=ollama
LOCAL_CHAT_MODEL=llama3.2-vision

# Image generation — pick one (or leave both empty for SVG sprites)

# Option: same endpoint also supports OAI-style image generation
# (e.g. Together.ai with FLUX, or a local wrapper)
# LOCAL_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# Option: Automatic1111 / compatible Stable Diffusion REST API
# LOCAL_SD_URL=http://host.docker.internal:7860

# ── App settings ──────────────────────────────────────────────────────────────
SESSION_PORT=3000
