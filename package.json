{
  "name": "kidsproject",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "server"
  ],
  "scripts": {
    "dev": "concurrently --names server,session \"npm run dev -w @kidsproject/server\" \"npm run dev -w @kidsproject/session\"",
    "build": "npm run build -w @kidsproject/session",
    "typecheck": "tsc --build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  }
}
